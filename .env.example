# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_bot_client_id_here

# Optional: Channel ID for hourly auto-posts
# Right-click a channel in Discord > Copy Channel ID (enable Developer Mode in settings)
MONITORING_CHANNEL_ID=

# Discord webhook for GHA alerts and cron script alerts
DISCORD_WEBHOOK_MONITORING=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
